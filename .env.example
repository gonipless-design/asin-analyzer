# ASIN Analyzer - Environment Variables
# Copy this to .env and fill in values

# Port (Railway sets this automatically)
PORT=3000

# Optional: RainforestAPI key for real Amazon data (free tier available)
# Sign up at: https://www.rainforestapi.com
RAINFOREST_API_KEY=your_key_here

# Brevo (formerly Sendinblue) email API - free tier: 300 emails/day
# Sign up at: https://brevo.com
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@asinanalyzer.app

# Email notifications (optional - for getting lead alerts)
NOTIFY_EMAIL=your@email.com
